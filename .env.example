# ============================================================================
# Environment Variables Template for AimBritz Platform
# ============================================================================
# Copy this file to .env.local for local development
# Add actual values in Vercel dashboard for production

# ============================================================================
# PHASE 1: Not needed yet (static data)
# ============================================================================

# ============================================================================
# PHASE 2: Database & Admin Dashboard
# ============================================================================

# Database URL (PostgreSQL via Supabase)
# Example: postgresql://USER:PASSWORD@HOST:5432/DATABASE?pgbouncer=true
# DATABASE_URL="postgresql://..."

# Supabase (if using Supabase)
# NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Authentication - Option A: Clerk (Recommended)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
# CLERK_SECRET_KEY="sk_test_..."

# Authentication - Option B: NextAuth.js
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ============================================================================
# PHASE 3: AI Chatbot
# ============================================================================

# OpenAI API
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4-turbo"

# LangChain
# LANGCHAIN_API_KEY="..."
# LANGCHAIN_TRACING_V2="true"
# LANGCHAIN_PROJECT="aimbritz-chatbot"

# ============================================================================
# PHASE 5: File Uploads & Storage
# ============================================================================

# AWS S3 (Option A)
# AWS_ACCESS_KEY_ID="..."
# AWS_SECRET_ACCESS_KEY="..."
# AWS_REGION="us-east-1"
# AWS_BUCKET_NAME="aimbritz-documents"

# Cloudinary (Option B - Recommended for images)
# CLOUDINARY_CLOUD_NAME="..."
# CLOUDINARY_API_KEY="..."
# CLOUDINARY_API_SECRET="..."

# ============================================================================
# Email Service (Phase 2+)
# ============================================================================

# Resend (Recommended)
# RESEND_API_KEY="re_..."
# FROM_EMAIL="noreply@aimbritz.com"

# SendGrid (Alternative)
# SENDGRID_API_KEY="SG...."
# SENDGRID_FROM_EMAIL="noreply@aimbritz.com"

# ============================================================================
# Analytics & Monitoring
# ============================================================================

# Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Sentry (Error Tracking)
# SENTRY_DSN="https://..."
# SENTRY_AUTH_TOKEN="..."

# ============================================================================
# App Configuration
# ============================================================================

# Base URL
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Environment
# NODE_ENV="development"  # development | production

# ============================================================================
# Payment Gateway (if implementing fee payment)
# ============================================================================

# Stripe
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# ============================================================================
# Social Media API Keys (if implementing social login)
# ============================================================================

# Google OAuth
# GOOGLE_CLIENT_ID="..."
# GOOGLE_CLIENT_SECRET="..."

# Facebook OAuth
# FACEBOOK_CLIENT_ID="..."
# FACEBOOK_CLIENT_SECRET="..."

# ============================================================================
# Redis (for caching - optional)
# ============================================================================

# REDIS_URL="redis://localhost:6379"

# ============================================================================
# Rate Limiting (optional)
# ============================================================================

# RATE_LIMIT_MAX="100"
# RATE_LIMIT_WINDOW="15m"

# ============================================================================
# Feature Flags (optional)
# ============================================================================

# NEXT_PUBLIC_ENABLE_CHATBOT="false"
# NEXT_PUBLIC_ENABLE_ANALYTICS="true"
# NEXT_PUBLIC_ENABLE_TESTIMONIALS="true"

# ============================================================================
# NOTES
# ============================================================================
# 1. Never commit .env.local to version control
# 2. Update .gitignore to include .env*.local
# 3. For production, set these in Vercel dashboard
# 4. Use strong secrets: openssl rand -base64 32
# 5. Rotate keys regularly for security
